{
  "name": "tcw-web",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint web --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build": "node scripts/build_web.mjs",
    "check:build": "node scripts/check_web_build.mjs"
  },
  "dependencies": {
    "fastify": "5.6.1",
    "marked": "16.3.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router": "7.9.1"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@playwright/test": "1.55.0",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.3.1",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.2",
    "esbuild": "0.25.9",
    "eslint": "9.35.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "typescript": "5.9.2",
    "typescript-eslint": "8.42.0",
    "vite": "7.1.4",
    "vitest": "3.2.4"
  }
}
